# ---- Server ----
PORT=5000
CLIENT_URL=http://localhost:5173

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Database ----
# If left blank, the server auto-starts an in-memory MongoDB (great for demos, no install needed).
# For persistence, use a real MongoDB (local or MongoDB Atlas), e.g.:
# MONGODB_URI=mongodb://127.0.0.1:27017/skillswap
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/skillswap
MONGODB_URI=

# ---- AI Assistant (real LLM) ----
# Provider: gemini | openai | anthropic
AI_PROVIDER=gemini

# Gemini (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Starting time-credits granted to every new member
SIGNUP_BONUS_CREDITS=3
